{
  "name": "@imprint/openclaw-plugin",
  "version": "0.1.0",
  "description": "Multi-layered cognitive memory and task management for OpenClaw",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "sqlite-vec": "^0.1.9",
    "@xenova/transformers": "^2.17.2",
    "@sinclair/typebox": "^0.34.8",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
